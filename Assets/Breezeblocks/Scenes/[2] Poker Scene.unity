  playerStaminaController: {fileID: 457326135}
  playerHealth: {fileID: 457326122}
  globalLight2D: {fileID: 619394801}
  showSystemTime: 1
  pauseGameplayWhileOpen: 0
  maxLogEntries: 128
  commandHelpEntries:
  - commandId: help
    commandSyntax: help
    description: Lists all available console commands and what they do.
  - commandId: create_equipment
    commandSyntax: create_equipment_EQUIPMENTNAME
    description: Creates equipment by its display name and stores it in the player's
      equipment slots.
  - commandId: god_mode
    commandSyntax: god_mode true|false
    description: Turns player invincibility on or off.
  - commandId: invisible
    commandSyntax: invisible true|false
    description: Disables enemy vision detection against the player.
  - commandId: lightfooted
    commandSyntax: lightfooted true|false
    description: Disables enemy hearing reactions.
  - commandId: restart_level
    commandSyntax: restart_level
    description: Reloads the current level.
  - commandId: noclip
    commandSyntax: noclip true|false
    description: Gives infinite reserve ammo and throwable uses.
  - commandId: focus_mode
    commandSyntax: focus_mode true|false
    description: Restores focus to full and prevents focus from draining.
  - commandId: athlete_mode
    commandSyntax: athlete_mode true|false
    description: Restores stamina to full and prevents stamina from draining.
  - commandId: ghost_mode
    commandSyntax: ghost_mode true|false
    description: Disables the player's solid colliders so the player can pass through
      obstacles.
  - commandId: medusa_mode
    commandSyntax: medusa_mode true|false
    description: Turns the player vision cone into a 360 degree view or restores
      the default cone.
  - commandId: let_there_be_light
    commandSyntax: let_there_be_light true|false
    description: Enables or disables the _GLOBALLIGHT Light2D.
